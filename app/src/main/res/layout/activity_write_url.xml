<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="URL a escribir en la tarjeta"
        android:textStyle="bold"
        android:textSize="15sp"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/et_url"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="textUri"
        android:singleLine="false"
        android:minLines="3"
        android:hint="https://tudominio.com/nfc?..."
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btn_insert_placeholders"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📋 Insertar placeholder SDM..."
        android:backgroundTint="@color/button_secondary"
        android:layout_marginBottom="16dp" />

    <!-- Opciones adicionales -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Opciones"
        android:textStyle="bold"
        android:textSize="15sp"
        android:layout_marginBottom="8dp" />

    <CheckBox
        android:id="@+id/switch_create_app"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Crear aplicación NDEF si no existe"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Clave maestra de la app (hex, dejar vacío para clave por defecto)"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/et_app_key"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="00000000000000000000000000000000 (16 bytes)"
        android:inputType="textNoSuggestions"
        android:fontFamily="monospace"
        android:textSize="12sp"
        android:layout_marginBottom="16dp" />

    <!-- Botones de acción -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/btn_preview"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Vista previa"
            android:layout_marginEnd="8dp"
            android:backgroundTint="@color/button_secondary" />

        <Button
            android:id="@+id/btn_write"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="✏️ Escribir"
            android:backgroundTint="@color/accent" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:visibility="gone"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tv_result"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="El resultado aparecerá aquí"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:padding="12dp"
        android:background="@color/card_background" />

</LinearLayout>
</ScrollView>
